{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/admin", "dest": "/api/admin.php" },
    { "src": "/export", "dest": "/api/export.php" },
    { "src": "/university", "dest": "/api/university.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}