{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/admin.php", "dest": "/api/admin.php" },
    { "src": "/export.php", "dest": "/api/export.php" },
    { "src": "/university.php", "dest": "/api/university.php" },
    { "src": "/delete.php", "dest": "/api/delete.php" },
    { "src": "/insert.php", "dest": "/api/insert.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
